# ===== BUILD-TIME VARIABLES =====
# These variables are baked into the frontend JavaScript at build time
# If you change them, you need to rebuild: docker compose up -d --build

# API URL - How the browser will access the backend
# Same server (with proxy):  /api
# Remote server (direct):    https://api.yourbot.com/cabinet
VITE_API_URL=/api

# Telegram bot username for Login Widget (without @)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# ===== BRANDING (optional) =====
# App name displayed in header and browser tab
VITE_APP_NAME=VPN Cabinet

# Short logo text (1-2 characters, displayed in logo icon)
VITE_APP_LOGO=V

# ===== MOBILE DEEPLINKS (optional) =====
# Custom scheme used by native apps for app-only links:
# <scheme>://verify-email?token=... and <scheme>://reset-password?token=...
VITE_MOBILE_DEEPLINK_SCHEME=app

# Paths exposed through iOS Universal Links and Android App Links
MOBILE_DEEPLINK_PATHS=/verify-email*,/reset-password*

# iOS Universal Links app IDs: TEAM_ID.bundle.id[,TEAM_ID.bundle.id.beta]
MOBILE_IOS_APP_IDS=

# Android App Links package and release signing certificate fingerprints
MOBILE_ANDROID_PACKAGE_NAME=
MOBILE_ANDROID_SHA256_CERT_FINGERPRINTS=

# ===== RUNTIME VARIABLES =====

# Port to expose the frontend on host machine
# Default: 3020 (http://localhost:3020)
CABINET_PORT=3020
